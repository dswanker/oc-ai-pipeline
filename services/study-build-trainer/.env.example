# OC4 Study Build Trainer — environment variables
# Copy to .env and fill in real values. Do not commit .env.

# ─── Service ───────────────────────────────────────────────────────────
TRAINER_PORT=8001
TRAINER_LOG_LEVEL=info

# ─── Anthropic ─────────────────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...
ANTHROPIC_MODEL=claude-opus-4-7

# ─── monday.com ────────────────────────────────────────────────────────
# API token (NOT a personal access token — use a service account if possible)
MONDAY_API_TOKEN=

# Board: "Study Build Trainer — Corpus"
MONDAY_CORPUS_BOARD_ID=18410424473

# Webhook signing secret. Set this in the monday webhook config and here so
# the service can verify incoming webhooks.
MONDAY_WEBHOOK_SECRET=

# ─── clinicaltrials.gov ────────────────────────────────────────────────
# CT.gov API does not require auth. This is just for User-Agent identification.
CTGOV_USER_AGENT=oc-study-build-trainer/0.1 (contact: dswanker@openclinica.com)

# ─── Embedding model ───────────────────────────────────────────────────
EMBED_MODEL_NAME=BAAI/bge-large-en-v1.5
EMBED_DEVICE=cpu  # or "cuda" if GPU is available

# ─── Vector store ──────────────────────────────────────────────────────
# Path to the sqlite-vec database. Lives inside ./corpus/ by default.
VECTOR_DB_PATH=./corpus/embeddings.db

# Path where downloaded raw form designs and protocols are cached.
CORPUS_CACHE_DIR=./corpus/cache

# ─── Confidence threshold (CT.gov match) ───────────────────────────────
# Minimum composite score for auto-ingest. Below this, human review is
# required.
CTGOV_AUTO_INGEST_THRESHOLD=0.9
